// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  COORDINATOR
  TEACHER
  NONE
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String?
  image        String?
  role         Role    @default(NONE)
  passwordHash String?

  // Anti-abuse spend cap for the AI slide assistant (text + image generation).
  // Null = no cap. Spend is summed from AiUsageLog rows created at/after
  // aiSpendResetAt, so "releasing" a blocked user (see admin AI usage panel)
  // just bumps this timestamp forward instead of deleting log history.
  aiSpendCapUsd  Float?
  aiSpendResetAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Basic 1, Basic 2, ...
model Level {
  id    String @id @default(cuid())
  slug  String @unique
  title String
  order Int    @default(0)

  units Unit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Unit 1, Unit 2, ... within a level
model Unit {
  id      String @id @default(cuid())
  slug    String
  title   String
  order   Int    @default(0)
  levelId String

  level   Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([levelId, slug])
}

// Lesson A, Lesson B, ... within a unit
model Lesson {
  id     String @id @default(cuid())
  slug   String
  title  String
  order  Int    @default(0)
  unitId String

  unit  Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  parts Part[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([unitId, slug])
}

// Part 1, Part 2, ... within a lesson — this is the actual slide deck.
model Part {
  id       String @id @default(cuid())
  slug     String
  title    String
  order    Int    @default(0)
  lessonId String

  // Full slide deck, same shape as the presenter's `Slide[]` type.
  slides Json @default("[]")

  lesson       Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  pollSessions PollSession[]
  classSession ClassSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lessonId, slug])
}

// One persistent "join the class" session per Part — created lazily the
// first time it's needed and reused forever after for that same deck (today,
// tomorrow, next semester). Distinct from PollSession, which is always a
// fresh per-round row; this is the opposite: get-or-create, never recreated.
model ClassSession {
  id             String  @id @default(cuid())
  code           String  @unique
  partId         String  @unique
  currentSlideId String? // Slide.id of whatever the teacher is currently showing; null = not presenting right now

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One "round" of live voting for a poll slide — a fresh row is created each
// time the teacher (re-)opens voting on that slide, so re-runs never inherit
// old votes and old rounds stay around as history.
model PollSession {
  id       String @id @default(cuid())
  code     String @unique
  partId   String
  slideId  String
  question String // snapshot of the slide's question at round-start time
  status   String @default("open") // "open" | "closed"

  part    Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  createdAt DateTime  @default(now())
  closedAt  DateTime?
}

model PollOption {
  id            String @id @default(cuid())
  pollSessionId String
  label         String
  order         Int    @default(0)

  pollSession PollSession @relation(fields: [pollSessionId], references: [id], onDelete: Cascade)
  votes       PollVote[]
}

model PollVote {
  id            String @id @default(cuid())
  pollSessionId String
  optionId      String
  voterKey      String // opaque per-device id, from the voter's localStorage

  pollSession PollSession @relation(fields: [pollSessionId], references: [id], onDelete: Cascade)
  option      PollOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([pollSessionId, voterKey]) // one vote per device per round
}

// One row per OpenAI call made from the slide chat assistant (one text completion,
// or one image generation) — lets us estimate spend without leaving the app.
model AiUsageLog {
  id     String @id @default(cuid())
  kind   String // "text" | "image"
  userId String? // requester's User.id, when available

  model            String // e.g. "gpt-4.1-mini", "gpt-image-1"
  promptTokens     Int? // text calls only
  completionTokens Int? // text calls only
  imageSize        String? // image calls only, e.g. "1536x1024"
  imageQuality     String? // image calls only, e.g. "medium"
  estimatedCostUsd Float

  createdAt DateTime @default(now())
}
